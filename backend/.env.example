# AI attester signer — matches ATTESTER_SIGNER_ADDRESS in contracts/.env
# and the address passed to the Commitment.sol constructor at deploy.
ATTESTER_SIGNER_PRIVATE_KEY=
ATTESTER_SIGNER_ADDRESS=

MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz/
COMMITMENT_CONTRACT_ADDRESS=

# Local dev (Anvil, chain 31337)
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_COMMITMENT_CONTRACT_ADDRESS=

# AI judge: every provider below with a key set gets tried in order
# (Gemini -> Groq -> Anthropic), falling through automatically if one fails.
# If none are set, a deterministic stub judge is used instead of a real LLM
# call (passes anything over 20 characters — fine for local dev, not a demo).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=

# NETWORK=local or NETWORK=testnet, defaults to local
NETWORK=local
PORT=3001
